#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACE="${MB_WORKSPACE_HOME:-$(cd "$SCRIPT_DIR/.." && pwd)}"
PROJECTS_DIR="$WORKSPACE/projects"
SUBMITTED_FILE="$WORKSPACE/.projects/.mb_submitted"

mkdir -p "$PROJECTS_DIR" "$(dirname "$SUBMITTED_FILE")"
touch "$SUBMITTED_FILE"

# Tự động cấu hình lưu mật khẩu Git (nếu chưa có thiết lập nào khác bảo mật hơn như credential-manager)
if ! git config --global credential.helper | grep -q 'manager'; then
    git config --global credential.helper store
fi

GREEN="\033[1;32m"
YELLOW="\033[1;33m"
GRAY="\033[0;37m"
CYAN="\033[1;36m"
RESET="\033[0m"

# Kiem tra xem dang o trong 1 project hay khong
IN_PROJECT=false
if [[ "$PWD" == "$PROJECTS_DIR/"* ]] && [ -d .git ]; then
    IN_PROJECT=true
fi

show_project_menu() {
    echo -e "${CYAN}┌──────────── MB WORKSPACE ────────────┐${RESET}"
    # Sắp xếp project theo thời gian tạo/sửa mới nhất lên đầu
    mapfile -t projects < <(find "$PROJECTS_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %f\n' 2>/dev/null | sort -nr | cut -d' ' -f2-)
    for i in "${!projects[@]}"; do
        echo -e "│  [${i}] ${projects[$i]}"
    done
    echo -e "│  [C] Clone project mới"
    echo -e "│  [Q] Thoát"
    echo -e "${CYAN}└──────────────────────────────────────┘${RESET}"
    read -r -p "Chọn project hoặc clone: " choice

    if [[ "$choice" == "C" || "$choice" == "c" ]]; then
        if [ "$PWD" != "$WORKSPACE" ]; then
            echo -e "\n🔄 ${YELLOW}Đang tự động chuyển về thư mục gốc để Clone...${RESET}"
            cd "$WORKSPACE" || exit 1
        fi
        read -r -p "Nhập URL repo: " repo
        name=$(basename "$repo" .git)
        git clone "$repo" "$PROJECTS_DIR/$name"
        cd "$PROJECTS_DIR/$name" || exit 1
        echo "Đã clone và vào project: $name"
    elif [[ "$choice" == "Q" || "$choice" == "q" ]]; then
        exit 0
    elif [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -lt "${#projects[@]}" ]; then
        project=${projects[$choice]}
        cd "$PROJECTS_DIR/$project" || exit 1
        echo "Đã chọn project: $project"
    else
        echo "❌ Lựa chọn không hợp lệ"
        exit 1
    fi
}

handle_dirty_workspace() {
    if [[ -z $(git status --porcelain) ]]; then
        return 0
    fi
    
    while true; do
        echo -e "\n⚠️  ${YELLOW}Bạn đang có mã nguồn vừa sửa nhưng chưa được lưu!${RESET}"
        echo -e "│  [1] Hãy mang những thay đổi này sang task MỚI"
        echo -e "│  [2] Lưu lại vào task HIỆN TẠI trước khi chuyển"
        echo -e "│  [C] Xem danh sách các file đang bị thay đổi"
        echo -e "│  [Q] Hủy, tôi không muốn chuyển task nữa"
        read -r -p "👉 Lựa chọn của bạn [1/2/C/Q]: " dirty_choice

        if [[ "$dirty_choice" == "1" ]]; then
            return 0
        elif [[ "$dirty_choice" == "2" ]]; then
            read -r -p "📝 Nhập message để lưu task hiện tại: " commit_msg
            if [ -n "$commit_msg" ]; then
                "$WORKSPACE/mb-tools/mb-save" "$commit_msg"
                return 0
            else
                echo "❌ Bạn chưa nhập message. Đã hủy."
                return 1
            fi
        elif [[ "$dirty_choice" == "C" || "$dirty_choice" == "c" ]]; then
            echo -e "\n${CYAN}--- Danh sách file thay đổi ---${RESET}"
            git status -s
            echo -e "${CYAN}-------------------------------${RESET}\n"
        elif [[ "$dirty_choice" == "Q" || "$dirty_choice" == "q" ]]; then
            echo "❌ Đã hủy chuyển task."
            return 1
        else
            echo "❌ Lựa chọn không hợp lệ."
        fi
    done
}

handle_task() {
    local t=$1
    if git show-ref --verify --quiet "refs/heads/$t"; then
        git checkout "$t"
        echo "Đang làm task: $t"
    else
        # Kiem tra branch tren origin
        if git ls-remote --exit-code --heads origin "$t" >/dev/null 2>&1; then
            echo -e "\n⚠️  ${YELLOW}Task '$t' ĐÃ TỒN TẠI trên origin!${RESET}"
            read -r -p "👉 Bạn muốn Tải về (y) hay Hủy để đặt tên khác (n)? [y/N]: " ans
            if [[ "$ans" =~ ^[Yy]$ ]]; then
                git fetch origin "$t"
                git checkout -t "origin/$t"
                echo "Đã tải và chuyển sang task: $t"
            else
                echo "❌ Bị hủy."
                exit 1
            fi
        else
            git checkout -b "$t"
            echo "Đã tạo và chuyển sang task: $t"
        fi
    fi
}

show_task_menu() {
    local show_all=${1:-false}

    echo -e "\n${CYAN}┌────────── TASK MENU ──────────┐${RESET}"
    echo -e "│  ${YELLOW}Project:${RESET} $(basename "$PWD")"
    
    CURRENT=$(git branch --show-current)
    echo -e "│  ${GREEN}Task:${RESET} $CURRENT"
    echo -e "│"
    
    # Sắp xếp branch theo thời gian commit mới nhất lên đầu (loại bỏ master/main)
    mapfile -t branches < <(git branch --sort=-committerdate --format='%(refname:short)' | grep -vE '^(master|main)$')

    echo -e "│  ${CYAN}--- Chức năng ---${RESET}"
    echo -e "│  [S] Lưu task đang làm"
    echo -e "│  [D] Golive task"
    echo -e "│  [C] Xem các file thay đổi"
    if [ "$show_all" = false ] && [ ${#branches[@]} -gt 3 ]; then
        echo -e "│  [L] Hiển thị toàn bộ task"
    fi
    echo -e "│  [N] Tạo task mới"
    echo -e "│  [P] Chuyển dự án khác"
    echo -e "│  [Q] Thoát"
    echo -e "│"

    if [ ${#branches[@]} -eq 0 ]; then
        echo -e "│  (Chưa có task nào)"
    else
        echo -e "│  ${CYAN}--- Danh sách Task ---${RESET}"
        local max_tasks=${#branches[@]}
        if [ "$show_all" = false ] && [ $max_tasks -gt 3 ]; then
            max_tasks=3
        fi
        for (( i=0; i<max_tasks; i++ )); do
            task=${branches[$i]}
            mark=""
            color=$YELLOW
            if grep -Fxq "$task" "$SUBMITTED_FILE"; then mark=" [Đã nộp]"; color=$GRAY; fi
            if [ "$task" = "$CURRENT" ]; then mark=" [Đang làm]"; color=$GREEN; fi
            echo -e "│  [${i}] ${color}${task}${RESET}${mark}"
        done
        if [ "$show_all" = false ] && [ ${#branches[@]} -gt 3 ]; then
            echo -e "│  ... (còn $((${#branches[@]} - 3)) task khác)"
        fi
    fi
    echo -e "${CYAN}└──────────────────────────────┘${RESET}"

    read -r -p "Chọn chức năng hoặc task: " task_choice
    
    if [[ "$task_choice" == "L" || "$task_choice" == "l" ]]; then
        show_task_menu true
        return
    elif [[ "$task_choice" == "C" || "$task_choice" == "c" ]]; then
        echo -e "\n${CYAN}--- Danh sách file thay đổi ---${RESET}"
        git status -s
        if [[ -z $(git status --porcelain) ]]; then
            echo "(Không có thay đổi nào)"
        fi
        echo -e "${CYAN}-------------------------------${RESET}\n"
        read -r -p "Ấn Enter để quay lại menu..."
        show_task_menu "$show_all"
        return
    elif [[ "$task_choice" == "S" || "$task_choice" == "s" ]]; then
        read -r -p "📝 Nhập message commit: " commit_msg
        if [ -n "$commit_msg" ]; then
            "$WORKSPACE/mb-tools/mb-save" "$commit_msg"
        else
            echo "❌ Bạn chưa nhập message. Đã hủy lưu."
        fi
        sleep 1
        show_task_menu "$show_all"
        return
    elif [[ "$task_choice" == "D" || "$task_choice" == "d" ]]; then
        "$WORKSPACE/mb-tools/mb-submit"
        sleep 1
        show_task_menu "$show_all"
        return
    elif [[ "$task_choice" == "P" || "$task_choice" == "p" ]]; then
        show_project_menu
        show_task_menu false
        return
    elif [[ "$task_choice" =~ ^[0-9]+$ ]] && [ "$task_choice" -lt "${#branches[@]}" ]; then
        if [ "$show_all" = false ] && [ "$task_choice" -ge 3 ]; then
            echo "❌ Lựa chọn không hợp lệ (hãy bấm L để hiện toàn bộ task trước)."
            sleep 1
            show_task_menu "$show_all"
            return
        fi
        
        handle_dirty_workspace || { sleep 2; show_task_menu "$show_all"; return; }
        
        if git checkout "${branches[$task_choice]}"; then
            echo "✅ Task hiện tại: ${branches[$task_choice]}"
        else
            echo "❌ Lỗi: Xung đột mã nguồn! Không thể mang thay đổi sang nhánh cũ."
        fi
        sleep 2
        show_task_menu "$show_all"
        return
    elif [[ "$task_choice" == "N" || "$task_choice" == "n" ]]; then
        handle_dirty_workspace || { sleep 2; show_task_menu "$show_all"; return; }
        
        read -r -p "Nhập tên task mới: " new_task
        handle_task "$new_task"
        sleep 2
        show_task_menu "$show_all"
        return
    elif [[ "$task_choice" == "Q" || "$task_choice" == "q" ]]; then
        return 0
    elif [ -n "$task_choice" ]; then
        handle_dirty_workspace || { sleep 2; show_task_menu "$show_all"; return; }
        
        handle_task "$task_choice"
        sleep 2
        show_task_menu "$show_all"
        return
    else
        echo "❌ Lựa chọn không hợp lệ"
        sleep 1
        show_task_menu "$show_all"
        return
    fi
}

if [ "$IN_PROJECT" = false ]; then
    show_project_menu
fi

show_task_menu

if [ "$IN_PROJECT" = false ]; then
    # Mở IDE nếu có trên chính cửa sổ hiện tại (dùng cờ -r để reuse-window)
    if command -v antigravity &> /dev/null; then
        echo "Hiển thị thư mục trên Antigravity IDE..."
        antigravity -r . >/dev/null 2>&1 || true
    elif command -v code &> /dev/null; then
        echo "Hiển thị thư mục trên cửa sổ hiện tại..."
        code -r . >/dev/null 2>&1 || true
    elif command -v cursor &> /dev/null; then
        echo "Hiển thị thư mục trên cửa sổ hiện tại..."
        cursor -r . >/dev/null 2>&1 || true
    fi

    # Cuối cùng, mở một shell mới trong thư mục đã chọn để "giữ" người dùng ở đó
    echo -e "\n${GREEN}🚀 Đã sẵn sàng tại: $(pwd)${RESET}"
    exec $SHELL
else
    echo -e "\n${GREEN}🚀 Đã thoát MB Workspace.${RESET}"
    exit 0
fi
