#!/usr/bin/env bash
set -e

TASK=${1:-}

if [ -z "$TASK" ]; then
  echo "❌ Thiếu tên task"
  exit 1
fi

TASK=$(echo "$TASK" | awk '{print tolower($0)}')
TASK=$(echo "$TASK" | sed -e 's/[àáạảãâầấậẩẫăằắặẳẵ]/a/g' -e 's/[èéẹẻẽêềếệểễ]/e/g' -e 's/[ìíịỉĩ]/i/g' -e 's/[òóọỏõôồốộổỗơờớợởỡ]/o/g' -e 's/[ùúụủũưừứựửữ]/u/g' -e 's/[ỳýỵỷỹ]/y/g' -e 's/đ/d/g')
TASK=$(echo "$TASK" | sed -e 's/[^a-z0-9]/-/g' -e 's/-\{2,\}/-/g' -e 's/^-//' -e 's/-$//')


if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "⚠️ Bạn có thay đổi chưa commit. Hãy mb-save (phím S) trước."
  exit 1
fi

git fetch

if git show-ref --verify --quiet "refs/heads/$TASK"; then
  git checkout "$TASK"
else
  if git ls-remote --exit-code --heads origin "$TASK" >/dev/null 2>&1; then
    echo -e "\n⚠️  \033[1;33mTask '$TASK' ĐÃ TỒN TẠI trên origin!\033[0m"
    read -r -p "👉 Bạn muốn Tải về (y) hay Hủy để chọn tên khác (n)? [y/N]: " ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
      git checkout -t "origin/$TASK"
    else
      echo "❌ Bị hủy."
      exit 1
    fi
  else
    MAIN_BRANCH="master"
    if git show-ref --verify --quiet refs/heads/main; then
      MAIN_BRANCH="main"
    fi
    echo -e "\n🔄 \033[1;33mĐang chuyển về nhánh chính ($MAIN_BRANCH) và cập nhật...\033[0m"
    git checkout "$MAIN_BRANCH"
    git pull origin "$MAIN_BRANCH" || true
    git checkout -b "$TASK"
  fi
fi

echo "🚀 Đang làm task: $TASK"
